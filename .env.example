# Copy this file to .env and fill in your values.
# Get a free API key at https://openrouter.ai

# ── Required ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# ── Models (any OpenRouter slug works; these are tested defaults) ──────
EXTRACTION_MODEL=google/gemini-2.5-flash
REASONING_MODEL=google/gemini-2.5-flash

# ── Embedding model (downloaded locally on first run, ~120 MB) ─────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── Paths (defaults work when running from project root) ──────────────
POLICIES_DIR=./data/policies
SUBMISSIONS_DIR=./data/submissions
DB_PATH=./data/northwind.db

# ── Retrieval tuning ──────────────────────────────────────────────────
RETRIEVAL_TOP_K=6
RETRIEVAL_MIN_CONFIDENCE=0.18
